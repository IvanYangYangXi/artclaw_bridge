{
  "$comment": "将以下内容合并到 ~/.openclaw/openclaw.json 的 plugins 部分",

  "plugins": {
    "allow": ["mcp-bridge"],
    "entries": {
      "mcp-bridge": {
        "enabled": true,
        "config": {
          "servers": {
            "my-mcp-server": {
              "type": "websocket",
              "url": "ws://127.0.0.1:8080"
            }
          }
        }
      }
    }
  }
}