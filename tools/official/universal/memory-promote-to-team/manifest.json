{
  "id": "official/memory-promote-to-team",
  "name": "memory-promote-to-team",
  "description": "将个人记忆中的高价值踩坑记录自动晋升到团队记忆（crash_rules.md / gotchas.md / conventions.md）。自动发现所有 DCC 的记忆文件。",
  "version": "1.2.0",
  "author": "ArtClaw",
  "source": "official",
  "targetDCCs": [],
  "createdAt": "2026-04-25 11:30:00",
  "updatedAt": "2026-04-25 11:56:00",
  "implementation": {
    "type": "script",
    "entry": "main.py",
    "function": "promote_to_team",
    "aiPrompt": "定期运行此工具，将个人记忆中的高价值踩坑记录晋升到团队记忆。先 dry_run=true 预览，确认后 dry_run=false 执行。"
  },
  "inputs": [
    {
      "id": "min_importance",
      "name": "最低重要性",
      "type": "number",
      "required": false,
      "default": 0.7,
      "min": 0.1,
      "max": 1.0,
      "step": 0.1,
      "description": "只晋升重要性 >= 此值的记录（0-1）"
    },
    {
      "id": "dry_run",
      "name": "预览模式",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "true=只列出候选不写入, false=实际写入团队记忆"
    }
  ],
  "outputs": [
    {
      "id": "report",
      "name": "晋升报告",
      "type": "string"
    }
  ],
  "triggers": [
    {
      "id": "weekly-auto-scan",
      "name": "每周自动扫描",
      "enabled": true,
      "trigger": {
        "type": "schedule",
        "mode": "cron",
        "cron": "0 10 * * 1"
      },
      "useDefaultFilters": false,
      "filters": {},
      "execution": {
        "mode": "notify",
        "timeout": 60
      },
      "parameterPreset": {
        "min_importance": 0.7,
        "dry_run": false
      }
    }
  ]
}
