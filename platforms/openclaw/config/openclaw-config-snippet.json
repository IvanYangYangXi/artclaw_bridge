{
  "$comment": "将以下内容合并到 ~/.openclaw/openclaw.json 的 plugins 部分",
  "$doc": "详见 INSTALL_GUIDE.md",

  "plugins": {
    "allow": ["mcp-bridge"],
    "entries": {
      "mcp-bridge": {
        "enabled": true,
        "config": {
          "servers": {
            "ue-editor-agent": {
              "type": "websocket",
              "url": "ws://127.0.0.1:8080"
            }
          }
        }
      }
    }
  },

  "$agents_example": {
    "$comment": "v2.6+ 每个 DCC 只有 1 个 MCP 工具，使用通配符即可",
    "agents": {
      "list": [
        {
          "id": "my-agent",
          "tools": {
            "allow": [
              "mcp_ue-editor-agent_*",
              "mcp_maya-primary_*",
              "mcp_max-primary_*",
              "mcp_blender-editor_*",
              "mcp_houdini-editor_*",
              "mcp_sp-editor_*",
              "mcp_sd-editor_*",
              "mcp_comfyui-editor_*"
            ]
          }
        }
      ]
    }
  }
}
