# ArtClaw Tool Manager - Environment Variables
# Copy this file to .env and fill in your values.
# Prefix: ARTCLAW_

# OpenClaw Gateway HTTP API
ARTCLAW_GATEWAY_API_URL=http://127.0.0.1:18789
# Leave empty to auto-detect from ~/.openclaw/openclaw.json
ARTCLAW_GATEWAY_TOKEN=
ARTCLAW_GATEWAY_AGENT_ID=
